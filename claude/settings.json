{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Agent",
      "Bash(bun:*)",
      "Bash(bzl:*)",
      "Bash(cargo:*)",
      "Bash(cat:*)",
      "Bash(cd:*)",
      "Bash(cp:*)",
      "Bash(ddtool:*)",
      "Bash(docker-compose:*)",
      "Bash(docker:*)",
      "Bash(du:*)",
      "Bash(echo:*)",
      "Bash(find:*)",
      "Bash(gh:*)",
      "Bash(git:*)",
      "Bash(go:*)",
      "Bash(gofmt:*)",
      "Bash(grep:*)",
      "Bash(head:*)",
      "Bash(identity:*)",
      "Bash(ls:*)",
      "Bash(make:*)",
      "Bash(mkdir:*)",
      "Bash(mv:*)",
      "Bash(node:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(pip:*)",
      "Bash(pkill:*)",
      "Bash(pnpm:*)",
      "Bash(poetry:*)",
      "Bash(pwd)",
      "Bash(python:*)",
      "Bash(rm -rf:./**)",
      "Bash(rm -rf:/tmp/**)",
      "Bash(rm -rf:~/github/.worktrees/**)",
      "Bash(rm:./**)",
      "Bash(rm:/tmp/**)",
      "Bash(rm:~/github/.worktrees/**)",
      "Bash(sip:*)",
      "Bash(tail:*)",
      "Bash(tar:*)",
      "Bash(touch:*)",
      "Bash(tree:*)",
      "Bash(uuidgen)",
      "Bash(which:*)",
      "Bash(yarn:*)",
      "Bash(yt-dlp:*)",
      "Edit",
      "Edit(/tmp/**)",
      "Edit(/var/tmp/**)",
      "Edit(~/.cache/**)",
      "Edit(~/github/.worktrees/**)",
      "Glob",
      "Grep",
      "LS",
      "mcp__plugin_atlassian-remote-mcp_atlassian-remote__*",
      "MultiEdit",
      "Read",
      "Read(/tmp/**)",
      "Read(/var/tmp/**)",
      "Read(~/.cache/**)",
      "Read(~/github/.worktrees/**)",
      "Read(~/go/**)",
      "Skill(atlassian-remote-mcp:*)",
      "Skill(claude-developer-platform)",
      "Skill(commit-commands:*)",
      "Skill(dd:*)",
      "TodoRead",
      "TodoWrite",
      "WebFetch",
      "WebSearch",
      "Write",
      "Write(/tmp/**)",
      "Write(/var/tmp/**)",
      "Write(~/.cache/**)",
      "Write(~/github/.worktrees/**)"
    ],
    "deny": [
      "Bash(sudo:*)",
      "Bash(chmod:*)",
      "Bash(chown:*)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)"
    ],
    "ask": []
  },
  "model": "sonnet",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/claudeception-activator.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/session-start-install.sh"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "atlassian-remote-mcp@datadog-claude-plugins": true,
    "startup-subagents@sboudrias-claude-plugins": true,
    "redblue@datadog-claude-plugins": true,
    "marketplace-auto-update@datadog-claude-plugins": true,
    "dd@datadog-claude-plugins": true,
    "osx-notifications@datadog-claude-plugins": true,
    "commit-commands@claude-code-plugins": true,
    "ralph-wiggum@claude-code-plugins": true,
    "user-context@datadog-claude-plugins": true,
    "common-mistakes@mat-brown-contrib": true,
    "go-code-reviewer@datadog-claude-plugins": true,
    "trajectory@mrlee-plugins": true,
    "appgate@datadog-claude-plugins": true,
    "slack@claude-plugins-official": true
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "network": {
      "allowedDomains": [
        "github.com",
        "*.github.com",
        "*.npmjs.org",
        "*.yarnpkg.com",
        "*.vercel.com",
        "*.unpkg.com",
        "*.jsdelivr.com",
        "*.ddbuild.io",
        "*.datad0g.com",
        "*.datadoghq.com",
        "*.youtube.com"
      ],
      "allowUnixSockets": [
        "//var/run/docker.sock",
        "~/.ssh/agent-socket"
      ],
      "allowLocalBinding": true
    },
    "filesystem": {
      "allowWrite": [
        "/plugins/cache",
        "//tmp",
        "//var/tmp",
        "//private/tmp/claude",
        "~/.cache"
      ]
    },
    "excludedCommands": [
      "docker",
      "git",
      "gh"
    ]
  },
  "effortLevel": "medium"
}
