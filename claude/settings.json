{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Agent",
      "Bash(bun:*)",
      "Bash(bzl:*)",
      "Bash(cargo:*)",
      "Bash(cat:*)",
      "Bash(cd:*)",
      "Bash(cp:*)",
      "Bash(ddtool:*)",
      "Bash(docker-compose:*)",
      "Bash(docker:*)",
      "Bash(du:*)",
      "Bash(echo:*)",
      "Bash(find:*)",
      "Bash(gh:*)",
      "Bash(git:*)",
      "Bash(go:*)",
      "Bash(gofmt:*)",
      "Bash(grep:*)",
      "Bash(head:*)",
      "Bash(identity:*)",
      "Bash(ls:*)",
      "Bash(make:*)",
      "Bash(mkdir:*)",
      "Bash(mv:*)",
      "Bash(node:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(pip:*)",
      "Bash(pkill:*)",
      "Bash(pnpm:*)",
      "Bash(poetry:*)",
      "Bash(pwd)",
      "Bash(python:*)",
      "Bash(rm -rf:./**)",
      "Bash(rm -rf:/tmp/**)",
      "Bash(rm -rf:~/github/.worktrees/**)",
      "Bash(rm:./**)",
      "Bash(rm:/tmp/**)",
      "Bash(rm:~/github/.worktrees/**)",
      "Bash(sip:*)",
      "Bash(tail:*)",
      "Bash(tar:*)",
      "Bash(touch:*)",
      "Bash(tree:*)",
      "Bash(uuidgen)",
      "Bash(which:*)",
      "Bash(yarn:*)",
      "Bash(yt-dlp:*)",
      "Edit",
      "Edit(/tmp/**)",
      "Edit(/var/tmp/**)",
      "Edit(~/.cache/**)",
      "Edit(~/github/.worktrees/**)",
      "Glob",
      "Grep",
      "LS",
      "mcp__plugin_atlassian-remote-mcp_atlassian-remote__*",
      "MultiEdit",
      "Read",
      "Read(/tmp/**)",
      "Read(/var/tmp/**)",
      "Read(~/.cache/**)",
      "Read(~/github/.worktrees/**)",
      "Read(~/go/**)",
      "Skill(atlassian-remote-mcp:*)",
      "Skill(claude-developer-platform)",
      "Skill(commit-commands:*)",
      "TodoRead",
      "TodoWrite",
      "WebFetch",
      "WebSearch",
      "Write",
      "Write(/tmp/**)",
      "Write(/var/tmp/**)",
      "Write(~/.cache/**)",
      "Write(~/github/.worktrees/**)"
    ],
    "deny": [
      "Bash(sudo:*)",
      "Bash(chmod:*)",
      "Bash(chown:*)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)"
    ],
    "ask": []
  },
  "model": "sonnet",
  "effortLevel": "medium",
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "filesystem": {
      "allowWrite": [
        "/plugins/cache",
        "//tmp",
        "//var/tmp",
        "//private/tmp/claude",
        "~/.cache"
      ]
    },
    "network": {
      "allowedDomains": [
        "github.com",
        "*.github.com",
        "*.npmjs.org",
        "*.yarnpkg.com",
        "*.vercel.com",
        "*.ddbuild.io",
        "*.datad0g.com",
        "*.datadoghq.com",
        "*.youtube.com"
      ],
      "allowUnixSockets": ["//var/run/docker.sock", "~/.ssh/agent-socket"],
      "allowLocalBinding": true
    },
    "excludedCommands": ["docker", "git", "gh"]
  }
}
